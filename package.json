{
  "name": "dulichcali",
  "private": true,
  "description": "Du Lich Cali — static hosting project. No build step.",
  "scripts": {
    "test:receptionist": "node tests/runner.js",
    "test:rules": "bash scripts/ai/rules_test.sh",
    "test:pricing": "node tests/pricing.test.js",
    "test:journeydays": "node tests/journey-days.test.js",
    "test:media": "node tests/tc-media.test.js && node tests/place-media-sanitize.test.js",
    "test:tasks": "node tests/tc-tasks.test.js && node tests/task-tracker-accept.test.js",
    "test:overview": "node tests/tc-overview.test.js",
    "test:dispatch": "node tests/driver-ranking.test.js",
    "test:depgraph": "node tests/tc-depgraph.test.js",
    "test:deals": "node tests/deal-threshold.test.js",
    "test:airports": "node tests/airport-pairs.test.js",
    "test:tickets": "node tests/ticket-deals.test.js",
    "test:weather": "node tests/weather.test.js",
    "test:tmevents": "node tests/ticketmaster-events.test.js",
    "test:i18n": "node tests/tc-i18n-parity.test.js",
    "test:mediaenrich": "node tests/tc-media-enrich.test.js",
    "auto:hair": "bash automation/auto_run.sh automation/prompts/hair_salon_system_audit.md",
    "auto:full": "bash automation/auto_run.sh automation/prompts/full_app_system_audit.md",
    "auto:phase1": "bash automation/auto_run.sh automation/prompts/phase1_hair_salon_fix.md"
  },
  "engines": {
    "node": ">=14"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.7.0"
  }
}
