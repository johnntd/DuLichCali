rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────────
    // isVendorMember: caller is authenticated AND their vendorUsers doc maps them to this vendorId.
    // Used to restrict writes to members of the specific vendor — prevents cross-vendor tampering.
    function isVendorMember(vendorId) {
      return request.auth != null
          && exists(/databases/$(database)/documents/vendorUsers/$(request.auth.uid))
          && get(/databases/$(database)/documents/vendorUsers/$(request.auth.uid)).data.vendorId == vendorId;
    }

    // ── Vendor top-level docs ─────────────────────────────────────────────────────
    // Public read: homepage checks vendor status without requiring auth.
    // Write: only authenticated members of that specific vendor (not just any auth user).
    match /vendors/{vendorId} {
      allow read:  if true;
      allow write: if isVendorMember(vendorId);
    }

    // ── Staff schedule/availability — public read, vendor-member write ────────────
    // Customers need name/schedule/specialties to book without authenticating.
    // IMPORTANT: compensation fields (compensationType, monthlyBasePay, hireDate, payNotes)
    // are NOT stored here — they live in staffCompensation (see below).
    match /vendors/{vendorId}/staff/{doc} {
      allow read:  if true;
      allow write: if isVendorMember(vendorId);
    }

    // ── Services catalog — public read, vendor-member write ──────────────────────
    match /vendors/{vendorId}/services/{doc} {
      allow read:  if true;
      allow write: if isVendorMember(vendorId);
    }

    // ── Staff compensation — SENSITIVE, never public ──────────────────────────────
    // Contains: compensationType, monthlyBasePay, hireDate, payNotes.
    // Never publicly readable. Only authenticated members of this specific vendor.
    // Future: tighten to role='owner' only once role-check helpers are added.
    match /vendors/{vendorId}/staffCompensation/{doc} {
      allow read, write: if isVendorMember(vendorId);
    }

    // ── Payroll periods — SENSITIVE, vendor-member only ───────────────────────────
    // Contains monthly payout records: totalOwed, amountPaidOut, payrollStatus per staff.
    // Never publicly readable. Vendor-member write (owner manages payouts).
    match /vendors/{vendorId}/payrollPeriods/{doc} {
      allow read, write: if isVendorMember(vendorId);
    }

    // ── Other vendor subcollections (menuItems, notifications, etc.) ──────────────
    // Auth required. Broad auth (not vendor-membership-only) to preserve admin.html access.
    // staffCompensation is explicitly handled above with tighter rules.
    match /vendors/{vendorId}/{sub=**} {
      allow read, write: if request.auth != null;
    }

    // ── Vendor user mappings ──────────────────────────────────────────────────────
    // Auth required — no anonymous enumeration of staff emails and roles.
    // Previously: allow read: if true (needed for setup-code check) — that check
    // actually runs AFTER Firebase Auth sign-in, so auth != null is safe here.
    match /vendorUsers/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Bookings — open (customer booking flow is unauthenticated) ────────────────
    match /bookings/{doc=**} {
      allow read, write: if true;
    }

    // ── Driver profiles — public read, auth write ─────────────────────────────────
    // Homepage availability check runs unauthenticated; drivers sign in to write.
    match /drivers/{driverId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // ── Driver user mappings — auth only ─────────────────────────────────────────
    match /driverUsers/{uid} {
      allow read, write: if request.auth != null;
    }

    // ── Driver compliance — auth only (sensitive license/insurance/registration) ──
    match /driver_compliance/{driverId} {
      allow read, write: if request.auth != null;
    }

    // ── Ride notifications — public create, auth read/update ─────────────────────
    match /rideNotifications/{notifId} {
      allow create: if true;
      allow read, update: if request.auth != null;
    }

    // ── Video render jobs — auth only ─────────────────────────────────────────────
    match /videoRenderJobs/{jobId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null;
    }

    // ── AI escalations — public create+read, auth update ─────────────────────────
    match /escalations/{escalationId} {
      allow create: if true;
      allow read:   if true;
      allow update: if request.auth != null;
    }

    // ── Dispatch queue — anonymous (customer booking flow) can create; auth can read/update ──
    // Customers are signed in anonymously when booking; anonymous auth satisfies request.auth != null.
    // The Cloud Function (Admin SDK) reads/writes via server-side bypass — no rule needed for it.
    match /dispatchQueue/{docId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null;
    }

    // ── Booking offers — auth read (drivers poll for their offers) ────────────────
    match /bookingOffers/{docId} {
      allow read: if request.auth != null;
      allow create, update: if false; // Cloud Function only (Admin SDK bypasses rules)
    }

    // ── Travel packages — public read, no client write (seeded by admin script) ──
    match /travel_packages/{pkgId} {
      allow read:  if true;
      allow write: if false; // seeded server-side only
    }

    // ── Travel bookings — open create (unauthenticated booking flow) ──────────────
    match /travel_bookings/{bookingId} {
      allow create: if true;
      allow read:   if true;
      allow update: if request.auth != null;
    }

    // ── Travel drivers — public read, auth write ──────────────────────────────────
    match /travel_drivers/{driverId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // ── Driver availability calendar — auth read, Cloud Function write only ───────
    // travel_drivers/{driverId}/assigned_dates/{YYYY-MM-DD}
    // Clients may read to show availability; only Cloud Function (Admin SDK) writes.
    match /travel_drivers/{driverId}/assigned_dates/{dateId} {
      allow read:  if request.auth != null;
      allow write: if false; // Admin SDK (Cloud Function) bypasses these rules
    }

    // ── Travel dispatch audit log — auth read, Cloud Function write only ─────────
    match /travel_dispatch/{bookingId} {
      allow read:  if request.auth != null;
      allow write: if false; // Admin SDK (Cloud Function) only
    }

    // ── Travel portal assignments — driver can read their own; CF writes ──────────
    // Drivers read: travel_driver_id == their ID (enforced client-side; all auth users may read)
    // No client write — Cloud Function (Admin SDK) owns these docs.
    match /travelAssignments/{docId} {
      allow read:  if request.auth != null;
      allow write: if false; // Admin SDK (Cloud Function) only
    }

    // ── Travel vehicles — public read, server write ───────────────────────────────
    match /travel_vehicles/{vehicleId} {
      allow read:  if true;
      allow write: if false; // seeded server-side only
    }

    // ── Vendor self-serve signups ──────────────────────────────────────────────
    // Vendors sign in anonymously to create submissions (anonymous auth qualifies).
    // Only non-anonymous (admin) accounts can update submissions (approve/reject).
    // Reads are open to any authenticated user (admin queries the full collection).
    // No one can delete submissions — they are permanent records.
    match /vendor_signups/{signupId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null;
      allow update: if request.auth != null
                 && request.auth.token.firebase.sign_in_provider != 'anonymous';
      allow delete: if false;
    }

    // ── Pending plan selections — funnel analytics (anonymous auth qualifies) ───
    // Written by vendor-signup.html on wizard load (fire-and-forget tracking).
    // Admin reads to see plan selection funnel. Immutable once created.
    match /pending_signups/{docId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null
                 && request.auth.token.firebase.sign_in_provider != 'anonymous';
      allow update: if false;
      allow delete: if false;
    }

    // ── Default deny ──────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
