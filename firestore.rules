rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Vendor data — any authenticated user can read/write
    match /vendors/{doc=**} {
      allow read, write: if request.auth != null;
    }

    // Vendor user mappings — read allowed without auth (setup screen checks before account creation)
    match /vendorUsers/{uid} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Bookings (used by main site)
    match /bookings/{doc=**} {
      allow read, write: if true;
    }

    // Everything else — deny by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
