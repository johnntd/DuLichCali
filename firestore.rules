rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────────
    // isVendorMember: caller is authenticated AND their vendorUsers doc maps them to this vendorId.
    // Used to restrict writes to members of the specific vendor — prevents cross-vendor tampering.
    // A vendorUsers doc may map a user via a singular vendorId OR a vendorIds[]
    // array (unified owner accounts managing multiple businesses). Both forms
    // must be honored — matching the dashboard auth gate — otherwise an owner's
    // writes (e.g. saving a promotion) are silently rejected.
    function isVendorMember(vendorId) {
      return request.auth != null
          && exists(/databases/$(database)/documents/vendorUsers/$(request.auth.uid))
          && (
               get(/databases/$(database)/documents/vendorUsers/$(request.auth.uid)).data.get('vendorId', '') == vendorId
            || (get(/databases/$(database)/documents/vendorUsers/$(request.auth.uid)).data.get('vendorIds', []) is list
                && vendorId in get(/databases/$(database)/documents/vendorUsers/$(request.auth.uid)).data.get('vendorIds', []))
          );
    }

    // isAdmin: operator account, identified by an email allowlist. Email/password
    // (and Google) sign-ins carry request.auth.token.email; anonymous sessions do
    // not, so they can never match. Keep this list in sync with admin operators.
    function isAdmin() {
      return request.auth != null
          && request.auth.token.firebase.sign_in_provider != 'anonymous'
          && request.auth.token.email in ['johnntd@gmail.com'];
    }

    function isAssignedDriver() {
      return request.auth != null
          && 'driver' in resource.data
          && resource.data.driver.driverId == request.auth.uid;
    }

    function isPortalVendorUser() {
      return request.auth != null
          && request.auth.token.firebase.sign_in_provider != 'anonymous'
          && exists(/databases/$(database)/documents/vendorUsers/$(request.auth.uid));
    }

    function driverUpdateFieldsOk() {
      return request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['status','statusUpdatedAt','statusUpdatedBy','statusHistory',
                         'acceptedAt','startedAt','completedAt','driverNotes']);
    }

    function isMobileBarberBookingCustomer() {
      return request.auth != null
          && (
              (resource.data.customerUid is string && resource.data.customerUid == request.auth.uid)
              || (resource.data.customerId is string && resource.data.customerId == request.auth.uid)
          );
    }

    function isValidMobileBarberBookingCreate() {
      // Guest booking requests are intentional for public customer pages.
      // Rules allow create-only pending requests; reads remain owner/vendor scoped.
      return request.resource.data.keys().hasAll([
            'vendorId', 'customerName', 'customerPhone', 'serviceId',
            'serviceName', 'address', 'city', 'zip', 'requestedDate',
            'startTime', 'endTime', 'status', 'source'
          ])
          && request.resource.data.status in ['pending_barber_confirmation', 'pending_confirmation', 'vendor_review']
          && request.resource.data.vendorId is string
          && request.resource.data.customerName is string
          && request.resource.data.customerPhone is string
          && request.resource.data.address is string
          && request.resource.data.city is string
          && request.resource.data.zip is string
          && request.resource.data.source in ['customer_form', 'ai_chat', 'ai_voice', 'ai_preview']
          && (!('customerId' in request.resource.data) || request.resource.data.customerId == request.auth.uid)
          && (!('customerUid' in request.resource.data) || request.resource.data.customerUid == request.auth.uid)
          // Price/discount sanity — a malicious direct write cannot inject a
          // negative price or a >100% discount. Fields are optional (older
          // payloads omit them), but when present they must be well-formed.
          && (!('servicePrice' in request.resource.data)
                || (request.resource.data.servicePrice is number && request.resource.data.servicePrice >= 0))
          && (!('amountDue' in request.resource.data)
                || (request.resource.data.amountDue is number && request.resource.data.amountDue >= 0))
          && (!('totalPrice' in request.resource.data)
                || (request.resource.data.totalPrice is number && request.resource.data.totalPrice >= 0))
          && (!('discountPercent' in request.resource.data)
                || (request.resource.data.discountPercent is number
                    && request.resource.data.discountPercent >= 0
                    && request.resource.data.discountPercent <= 100))
          // Customer-controlled status is already pinned to a pending value above.
          // paymentStatus may only be created as unpaid/pending — never 'paid'.
          && (!('paymentStatus' in request.resource.data)
                || request.resource.data.paymentStatus in ['unpaid', 'pending'])
          && request.resource.data.customerName.size() <= 120
          && request.resource.data.address.size() <= 300;
    }

    function isMobileBarberCustomerOwner() {
      return request.auth != null
          && (
              (resource.data.customerUid is string && resource.data.customerUid == request.auth.uid)
              || (resource.data.customerId is string && resource.data.customerId == request.auth.uid)
          );
    }

    function isValidMobileBarberCustomerCreate() {
      return request.auth != null
          && (
              request.resource.data.customerUid == request.auth.uid
              || request.resource.data.customerId == request.auth.uid
          )
          && (
              request.resource.data.customerPhoneNormalized is string
              || request.resource.data.normalizedPhone is string
          );
    }

    function isCustomerScopedCreate() {
      return request.auth != null
          && request.resource.data.customerId is string
          && request.resource.data.customerId == request.auth.uid
          && request.resource.data.size() <= 60;
    }

    function isCustomerScopedRead() {
      return request.auth != null
          && resource.data.customerId is string
          && resource.data.customerId == request.auth.uid;
    }

    // ── Vendor top-level docs ─────────────────────────────────────────────────────
    // Public read: homepage checks vendor status without requiring auth.
    // Write: only authenticated members of that specific vendor (not just any auth user).
    match /vendors/{vendorId} {
      allow read:  if true;
      allow write: if isVendorMember(vendorId) || isAdmin();
    }

    // ── Staff schedule/availability — public read, vendor-member write ────────────
    // Customers need name/schedule/specialties to book without authenticating.
    // IMPORTANT: compensation fields (compensationType, monthlyBasePay, hireDate, payNotes)
    // are NOT stored here — they live in staffCompensation (see below).
    match /vendors/{vendorId}/staff/{doc} {
      allow read:  if true;
      allow write: if isVendorMember(vendorId);
    }

    // ── Services catalog — public read, vendor-member write ──────────────────────
    match /vendors/{vendorId}/services/{doc} {
      allow read:  if true;
      allow write: if isVendorMember(vendorId);
    }

    // ── Staff compensation — SENSITIVE, never public ──────────────────────────────
    // Contains: compensationType, monthlyBasePay, hireDate, payNotes.
    // Never publicly readable. Only authenticated members of this specific vendor.
    // Future: tighten to role='owner' only once role-check helpers are added.
    match /vendors/{vendorId}/staffCompensation/{doc} {
      allow read, write: if isVendorMember(vendorId);
    }

    // ── Payroll periods — SENSITIVE, vendor-member only ───────────────────────────
    // Contains monthly payout records: totalOwed, amountPaidOut, payrollStatus per staff.
    // Never publicly readable. Vendor-member write (owner manages payouts).
    match /vendors/{vendorId}/payrollPeriods/{doc} {
      allow read, write: if isVendorMember(vendorId);
    }

    match /vendors/{vendorId}/inventory/{doc} {
      allow read, write: if isVendorMember(vendorId);
    }

    // ── Email queue — customer booking flow writes confirmation emails here ─────
    // Public create only (booking flow is unauthenticated). Read/update gated to
    // authenticated callers; Functions trigger uses admin SDK so it bypasses rules.
    match /vendors/{vendorId}/emailQueue/{queueId} {
      // Create now requires auth (the booking flow signs in anonymously first),
      // closing the unauthenticated email-spam vector. App Check / rate limiting
      // is the recommended follow-up for anon-authed abuse.
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null;
    }

    // ── Other vendor subcollections (menuItems, notifications, etc.) ──────────────
    // Read stays auth-only (display data, no anonymous enumeration of the path is
    // worsened vs. before). WRITE is now restricted to the vendor's own members
    // or an admin — previously ANY authenticated (incl. anonymous) user could
    // write any vendor's subcollections (cross-vendor tampering / fake
    // notifications). staffCompensation/payroll are handled above with tighter rules.
    match /vendors/{vendorId}/{sub=**} {
      allow read:  if request.auth != null;
      allow write: if isVendorMember(vendorId) || isAdmin();
    }

    // ── Vendor user mappings ──────────────────────────────────────────────────────
    // Auth required — no anonymous enumeration of staff emails and roles.
    // SECURITY: clients can NO LONGER self-map. A write is allowed only for an
    // admin, OR an existing member of the SAME vendor (so an owner can add staff
    // to their own vendor). The FIRST membership for a vendor is created by the
    // `claimVendorMembership` Cloud Function AFTER it verifies the setup-code (PIN)
    // server-side (Admin SDK bypasses this rule). This fully closes the
    // email/password self-map takeover: a non-member cannot grant itself any vendor.
    match /vendorUsers/{uid} {
      allow read:  if request.auth != null;
      allow write: if isAdmin()
                || isVendorMember(request.resource.data.get('vendorId', '__nomatch__'));
    }

    // ── Bookings (airport/ride) ───────────────────────────────────────────────────
    // Was fully open (allow read, write: if true) — an unauthenticated attacker
    // could read every customer's name/phone/pickup-dropoff and overwrite/delete
    // any booking. Every real consumer (booking form, tracking.html, drivers,
    // admin) signs in (anonymously or with an account) first, so requiring auth
    // closes the unauthenticated hole without breaking the flows. Guest create
    // stays open. Dispatch Cloud Functions use the Admin SDK (bypass rules).
    // Residual (documented): an anonymous session can still read a booking by a
    // known id — finer per-customer scoping needs a customerUid/token (follow-up).
    match /bookings/{doc=**} {
      allow create: if true;
      // get (single doc by id) is how a customer tracks their own booking via
      // the link they were sent — kept open to any auth session. list (querying
      // the whole collection) is restricted to admin/vendor/driver accounts so
      // an anonymous attacker cannot enumerate every customer's PII. (The
      // homepage's advisory conflict check listed all bookings as anon; it now
      // degrades gracefully and a Cloud Function aggregate is the follow-up.)
      allow get:    if request.auth != null;
      allow list:   if isAdmin() || isPortalVendorUser() || isAssignedDriver();
      // Updates (status/payment/driver/price) come only from admin + the driver
      // portal, both NON-anonymous. Block anonymous updates so a customer can't
      // forge status='completed' / paymentStatus='paid' / a different driver.
      allow update: if isAdmin() || isPortalVendorUser()
                 || (isAssignedDriver() && driverUpdateFieldsOk());
      allow delete: if isAdmin();
    }

    // ── Driver profiles — public read; admin-managed; driver self-edits non-approval fields ──
    // Homepage availability check runs unauthenticated (public read). Admin creates
    // drivers + owns the compliance/approval fields. A driver may edit their own
    // profile but can NEVER self-approve: complianceStatus + the licence/registration/
    // insurance expiry mirrors (which gate availability) are admin-only. Anonymous
    // accounts cannot write at all — previously any anon user could self-insert an
    // "approved/active" driver and receive customer rides + PII.
    match /drivers/{driverId} {
      allow read:   if true;
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if isAdmin()
                 || (request.auth != null
                     && request.auth.token.firebase.sign_in_provider != 'anonymous'
                     && request.auth.uid == driverId
                     && !request.resource.data.diff(resource.data).affectedKeys()
                          .hasAny(['complianceStatus', 'adminStatus', 'licExpiry', 'regExpiry', 'insExpiry']));
    }

    match /drivers/{driverId}/pushSubscriptions/{subId} {
      allow read, write: if request.auth != null && request.auth.uid == driverId;
    }

    // ── Driver user mappings — auth only ─────────────────────────────────────────
    match /driverUsers/{uid} {
      allow read, write: if request.auth != null;
    }

    // ── Driver compliance — sensitive (license/insurance/registration) ──
    // Read: admin or the driver's own docs. Write: admin (review/approve) or the
    // driver editing their OWN submission (non-anonymous). Anonymous blocked.
    match /driver_compliance/{driverId} {
      allow read:  if isAdmin() || (request.auth != null && request.auth.uid == driverId);
      allow write: if isAdmin()
                || (request.auth != null
                    && request.auth.token.firebase.sign_in_provider != 'anonymous'
                    && request.auth.uid == driverId);
    }

    // ── Ride notifications — create requires auth (anon booking flow qualifies) ──
    // Was public create → unauthenticated push-notification spam to drivers.
    match /rideNotifications/{notifId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null;
    }

    // ── Video render jobs — auth only ─────────────────────────────────────────────
    match /videoRenderJobs/{jobId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null;
    }

    // ── AI escalations — create open (anon booking flow), read auth-only ─────────
    // Read was public, leaking support-ticket contents (disputes, PII) to
    // unauthenticated requests. Now requires auth.
    match /escalations/{escalationId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null;
      allow update: if request.auth != null;
    }

    // ── Dispatch queue — anonymous (customer booking flow) can create; auth can read/update ──
    // Customers are signed in anonymously when booking; anonymous auth satisfies request.auth != null.
    // The Cloud Function (Admin SDK) reads/writes via server-side bypass — no rule needed for it.
    match /dispatchQueue/{docId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null;
    }

    // ── Booking offers — auth read (drivers poll for their offers) ────────────────
    match /bookingOffers/{docId} {
      allow read: if request.auth != null;
      allow create, update: if false; // Cloud Function only (Admin SDK bypasses rules)
    }

    // ── Travel packages — public read, no client write (seeded by admin script) ──
    match /travel_packages/{pkgId} {
      allow read:  if true;
      allow write: if false; // seeded server-side only
    }

    // ── Travel bookings ───────────────────────────────────────────────────────────
    // Guest create stays open; read now requires auth (was public — leaked all
    // customer names/phones/destinations to unauthenticated requests).
    match /travel_bookings/{bookingId} {
      allow create: if true;
      allow get:    if request.auth != null;
      allow list:   if isAdmin() || isPortalVendorUser();
      // Updates (status/payment/driver/price) come only from admin + the driver
      // portal, both NON-anonymous. Block anonymous updates so a customer can't
      // forge status='completed' / paymentStatus='paid' / a different driver.
      allow update: if isAdmin() || isPortalVendorUser();
      allow delete: if isAdmin();
    }

    // ── Travel drivers — public read, auth write ──────────────────────────────────
    match /travel_drivers/{driverId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // ── Driver availability calendar — auth read, Cloud Function write only ───────
    // travel_drivers/{driverId}/assigned_dates/{YYYY-MM-DD}
    // Clients may read to show availability; only Cloud Function (Admin SDK) writes.
    match /travel_drivers/{driverId}/assigned_dates/{dateId} {
      allow read:  if request.auth != null;
      allow write: if false; // Admin SDK (Cloud Function) bypasses these rules
    }

    // ── Travel dispatch audit log — auth read, Cloud Function write only ─────────
    match /travel_dispatch/{bookingId} {
      allow read:  if request.auth != null;
      allow write: if false; // Admin SDK (Cloud Function) only
    }

    // ── Travel portal assignments — driver can read their own; CF writes ──────────
    // Drivers read: travel_driver_id == their ID (enforced client-side; all auth users may read)
    // No client write — Cloud Function (Admin SDK) owns these docs.
    match /travelAssignments/{docId} {
      allow read:  if isAdmin() || isPortalVendorUser()
                || (request.auth != null && resource.data.travel_driver_id == request.auth.uid);
      allow write: if false; // Admin SDK (Cloud Function) only
    }

    // ── Travel vehicles — public read, server write ───────────────────────────────
    match /travel_vehicles/{vehicleId} {
      allow read:  if true;
      allow write: if false; // seeded server-side only
    }

    // ── Vendor self-serve signups ──────────────────────────────────────────────
    // Vendors sign in anonymously to create submissions (anonymous auth qualifies).
    // Only non-anonymous (admin) accounts can update submissions (approve/reject).
    // Reads are open to any authenticated user (admin queries the full collection).
    // No one can delete submissions — they are permanent records.
    match /vendor_signups/{signupId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null;
      allow update: if request.auth != null
                 && request.auth.token.firebase.sign_in_provider != 'anonymous';
      allow delete: if false;
    }

    // ── Pending plan selections — funnel analytics (anonymous auth qualifies) ───
    // Written by vendor-signup.html on wizard load (fire-and-forget tracking).
    // Admin reads to see plan selection funnel. Immutable once created.
    match /pending_signups/{docId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null
                 && request.auth.token.firebase.sign_in_provider != 'anonymous';
      allow update: if false;
      allow delete: if false;
    }

    // ── Mobile Barber public catalog — safe public data only ─────────────────────
    match /mobileBarberVendors/{vendorId} {
      allow read: if true;
      allow write: if isVendorMember(vendorId) || isAdmin();

      // Web Push subscriptions for the vendor portal PWA. Only the authenticated
      // vendor member (or admin) may register/read a device subscription — a
      // customer can NEVER register themselves as a notification recipient.
      // The send-side Cloud Function uses the Admin SDK and bypasses these rules.
      match /pushSubscriptions/{subId} {
        allow read, write: if isVendorMember(vendorId) || isAdmin();
      }
    }

    match /mobileBarberServices/{serviceId} {
      allow read: if true;
      allow write: if isVendorMember(request.resource.data.vendorId) || isAdmin();
    }

    match /mobileBarberAvailability/{availabilityId} {
      allow read: if true;
      allow write: if isVendorMember(request.resource.data.vendorId) || isAdmin();
    }

    // ── Mobile Barber private bookings — customer address protected ──────────────
    // Public pages may create pending requests but cannot read booking documents.
    // Reads are limited to the signed-in booking owner or the involved vendor.
    match /mobileBarberBookings/{bookingId} {
      allow create: if isValidMobileBarberBookingCreate();
      allow read: if isMobileBarberBookingCustomer()
               || isVendorMember(resource.data.vendorId)
               || isAdmin();
      // The assigned vendor/owner has full control (accept, reschedule, mark
      // paid, complete). The booking owner (customer) may only edit benign
      // fields and cancel — they can NEVER change money, vendor, or flip status
      // to confirmed/paid/completed. This is the server-side enforcement of
      // "customers cannot tamper with booking status/price/payment".
      allow update: if isVendorMember(resource.data.vendorId)
                 || isAdmin()
                 || (
                      isMobileBarberBookingCustomer()
                      && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
                           'vendorId', 'ownerId', 'assignedBarberId', 'serviceType',
                           'servicePrice', 'travelFee', 'amountDue', 'totalPrice',
                           'vehicleWearCost', 'distanceAdjustment', 'peakAdjustment',
                           'paymentStatus', 'promotionId', 'promotionName', 'discountPercent',
                           'originalPrice', 'discountedPrice', 'promoApplied', 'reviewReason'
                         ])
                      && (request.resource.data.status == resource.data.status
                          || request.resource.data.status == 'cancelled')
                    );
      allow delete: if false;
    }

    // ── Mobile Barber customer profiles — private owner/vendor cut history ───────
    match /mobileBarberCustomers/{customerId} {
      allow create: if isValidMobileBarberCustomerCreate();
      // Vendors may read a customer profile ONLY for a customer they have an
      // assigned booking with: the profile's current vendorId must be one they are
      // a member of AND a vendorAccess marker (written by the Admin-SDK booking
      // trigger when a booking exists) must be present. This scopes vendor reads to
      // assigned bookings and prevents reads via a stale/forged vendorId field.
      allow read: if (request.auth != null && customerId == request.auth.uid)
               || isMobileBarberCustomerOwner()
               || (resource.data.vendorId is string
                   && isVendorMember(resource.data.vendorId)
                   && exists(/databases/$(database)/documents/mobileBarberCustomers/$(customerId)/vendorAccess/$(resource.data.vendorId)));
      // Vendors READ their customers (booking context) but must NOT modify the
      // customer-owned profile (PII / saved addresses / preferences / history).
      // Only the owner writes it client-side; Cloud Functions use the Admin SDK.
      // Owner is matched by the doc id (== uid) so a read succeeds even before the
      // profile doc is first written (avoids a permission-denied race right after sign-up).
      allow update: if (request.auth != null && customerId == request.auth.uid)
                 || isMobileBarberCustomerOwner();
      allow delete: if false;

      match /pushSubscriptions/{subId} {
        allow read, write: if request.auth != null && customerId == request.auth.uid;
      }

      // vendorAccess markers are maintained only by the Admin-SDK booking trigger
      // (which bypasses rules). The parent read rule's exists() check on these docs
      // works regardless of these client rules, so clients get no direct access.
      match /vendorAccess/{vid} {
        allow read, write: if false;
      }
    }

    match /customerNotifications/{notificationId} {
      allow read: if isCustomerScopedRead();
      // Customer may only flip benign read/dismiss flags — never rewrite vendor-set
      // content or reassign customerId (so a notification can't be reparented to another user).
      allow update: if isCustomerScopedRead()
                 && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt', 'updatedAt', 'dismissedAt']);
      allow create: if isCustomerScopedCreate();
      allow delete: if false;
    }

    match /customerSavedStyles/{styleId} {
      allow create: if isCustomerScopedCreate();
      allow read: if isCustomerScopedRead();
      allow update: if isCustomerScopedCreate() && isCustomerScopedRead();
      allow delete: if isCustomerScopedRead();
    }

    match /customerReminderPreferences/{prefId} {
      allow create: if request.auth != null && prefId == request.auth.uid && isCustomerScopedCreate();
      allow read: if request.auth != null && prefId == request.auth.uid && isCustomerScopedRead();
      allow update: if request.auth != null && prefId == request.auth.uid && isCustomerScopedCreate();
      allow delete: if false;
    }

    match /mobileBarberAgentSessions/{sessionId} {
      allow create: if request.auth != null
                 && request.resource.data.customerUid is string
                 && request.resource.data.customerUid == request.auth.uid;
      allow read, update: if request.auth != null
                       && resource.data.customerUid == request.auth.uid;
      allow delete: if false;
    }

    match /mobileBarberWaitlist/{waitlistId} {
      allow create: if request.resource.data.email is string
                 && request.resource.data.email.size() > 0
                 && request.resource.data.city is string
                 && request.resource.data.city.size() > 0;
      allow read, update, delete: if false;
    }

    // ── Audit logs — IMMUTABLE, server-written ───────────────────────────────────
    // Written ONLY by Cloud Function triggers (Admin SDK, which bypasses these
    // rules). No client may create, modify, or delete an audit entry — so the
    // record of who-changed-what-when cannot be forged or erased. Admins read
    // all; a vendor reads entries scoped to their own vendorId.
    match /auditLogs/{logId} {
      allow read:   if isAdmin() || isVendorMember(resource.data.vendorId);
      allow create, update, delete: if false;
    }

    // ── AI provider keys — SECURED, server-only ──────────────────────────────────
    // The Gemini/OpenAI/Claude keys used by the AI Cloud Functions (aiProxy /
    // aiOrchestrate / aiTtsProxy) live here. The functions read them via the
    // Admin SDK (which bypasses rules). This doc is NEVER client-readable
    // (`read: if false`) so a key can never be served to a browser; an admin may
    // WRITE (set/rotate) keys but cannot read them back. This is the "secured
    // firestore" key store — the safe replacement for the old public vendor docs.
    match /config/aiSecrets {
      allow read:  if false;
      allow write: if isAdmin();
    }

    // ── Security alerts — defense-in-depth event log ─────────────────────────────
    // Client-side runtime guards (which run in any visitor's browser, incl.
    // anonymous) may CREATE a validated alert. Only an admin (or the vendor the
    // alert is scoped to) may READ them or mark them resolved — never public.
    // This is a monitoring aid, NOT a security boundary; the Firestore rules
    // above are the real enforcement.
    match /securityAlerts/{alertId} {
      allow create: if request.resource.data.keys().hasAll(['severity', 'type', 'message', 'resolved', 'createdAt'])
                 && request.resource.data.severity in ['critical', 'high', 'medium', 'low']
                 && request.resource.data.type is string
                 && request.resource.data.type.size() <= 80
                 && request.resource.data.message is string
                 && request.resource.data.message.size() <= 1000
                 && request.resource.data.resolved == false;
      allow read:   if isAdmin() || isVendorMember(resource.data.vendorId);
      allow update: if (isAdmin() || isVendorMember(resource.data.vendorId))
                 && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['resolved', 'resolvedAt', 'resolvedBy']);
      allow delete: if isAdmin();
    }

    // ── Default deny ──────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
