rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Vendor top-level docs — publicly readable (homepage vendor status check),
    // auth-only write (admin + vendor-admin both sign in via Firebase Auth).
    match /vendors/{vendorId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }
    // Staff and services are public-facing data (customers need to see schedules
    // and service menus without authenticating). Explicit rules here take precedence
    // over the catch-all subcollection rule below.
    match /vendors/{vendorId}/staff/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /vendors/{vendorId}/services/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Other vendor subcollections (menuItems, bookings, notifications) — auth only.
    match /vendors/{vendorId}/{sub=**} {
      allow read, write: if request.auth != null;
    }

    // Vendor user mappings — public read needed for setup-code check before account creation.
    match /vendorUsers/{uid} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Bookings — open (customer creates, admin reads/updates, no auth in ride form).
    match /bookings/{doc=**} {
      allow read, write: if true;
    }

    // Driver profiles — publicly readable (homepage availability check runs unauthenticated),
    // auth-only write (drivers sign in before editing; admin creates via REST API).
    match /drivers/{driverId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // Driver user mappings — auth only.
    match /driverUsers/{uid} {
      allow read, write: if request.auth != null;
    }

    // Driver compliance documents — auth only (contains sensitive license/insurance/registration info).
    // Drivers write their own submissions; admin writes review decisions.
    // NOT publicly readable — compliance data is internal.
    match /driver_compliance/{driverId} {
      allow read, write: if request.auth != null;
    }

    // Ride booking notifications for active drivers — public create (ride form is unauthenticated),
    // auth read (drivers read their notifications after signing in to driver-admin).
    match /rideNotifications/{notifId} {
      allow create: if true;
      allow read, update: if request.auth != null;
    }

    // Video render job queue — authenticated vendors only.
    match /videoRenderJobs/{jobId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null;
    }

    // AI-to-vendor escalations — public create+read; vendor update requires auth.
    match /escalations/{escalationId} {
      allow create: if true;
      allow read:   if true;
      allow update: if request.auth != null;
    }

    // Everything else — deny by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
